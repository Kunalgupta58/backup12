# --- Database ---
# Option A: Render Postgres (preferred for production)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Option B: Supabase Postgres
# SUPABASE_DB_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require

# --- JWT ---
SECRET_KEY=change-me-before-production-use-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- Concurrency (keep at 1 — each worker loads the full ML model) ---
WEB_CONCURRENCY=1
